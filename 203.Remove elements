
class Solution {
    public ListNode removeElements(ListNode head, int val) {
        ListNode nn=new ListNode(0);
        nn.next=head;
        ListNode dummy=nn;
        while(dummy!=null && dummy.next!=null){
            if(dummy.next.val==val){
                dummy.next=dummy.next.next;
            }else{
                dummy=dummy.next;
            }} return nn.next;
        }}
        
       
